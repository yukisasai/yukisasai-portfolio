# お問い合わせフォームのメール送信設定（実値は .env.local に書く・コミットしない）
# Resend (https://resend.com) を利用。3つすべて設定するとフォームが実際に送信されます。

# 受信先メール（将来設定予定）
CONTACT_EMAIL=hello@yukisasai.com

# 送信元（Resend で検証済みドメインのアドレス。未設定なら onboarding@resend.dev を使用）
CONTACT_FROM=Portfolio <hello@yukisasai.com>

# Resend の API キー
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
